// Prisma schema for Farther AX Command Center
// Database: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Advisor profile data cached from HubSpot
model Advisor {
  id                String   @id @default(cuid())
  hubspot_id        String   @unique

  // Core Profile
  name              String
  email             String?
  phone             String?
  pathway           String?   // breakaway, independent_ria, ma, no_low_aum

  // Onboarding Status
  status            String?   // pipeline, early_deal, launched, graduated
  launch_date       DateTime?
  graduation_date   DateTime?
  axm_owner         String?
  axa_owner         String?
  ctm_owner         String?

  // Financial Data
  aum               Decimal?  @db.Decimal(15,2)
  revenue           Decimal?  @db.Decimal(15,2)
  account_count     Int?
  household_count   Int?

  // Complexity & Metrics
  complexity_score  Int?
  health_score      String?
  sentiment         String?   // positive, neutral, negative, unknown

  // Location & Background
  city              String?
  state             String?
  previous_firm     String?

  // Properties (Full HubSpot data as JSON for flexibility)
  properties        Json?

  // Activities
  activities        AdvisorActivity[]

  // Metadata
  last_synced_at    DateTime  @default(now())
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([hubspot_id])
  @@index([status])
  @@index([pathway])
  @@index([axm_owner])
  @@index([launch_date])
  @@index([last_synced_at])
  @@map("advisors")
}

// Advisor activities (notes, emails, calls, meetings) cached from HubSpot
model AdvisorActivity {
  id              String   @id @default(cuid())
  advisor_id      String
  hubspot_id      String   @unique // HubSpot engagement/note ID

  // Activity Details
  type            String   // note, email, call, meeting, task
  subject         String?
  body            String?  @db.Text
  timestamp       DateTime

  // Metadata
  created_by      String?  // HubSpot user who created it
  owner_id        String?  // HubSpot owner ID

  // Full HubSpot engagement data as JSON
  properties      Json?

  // Relations
  advisor         Advisor  @relation(fields: [advisor_id], references: [id], onDelete: Cascade)

  // Timestamps
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([advisor_id])
  @@index([timestamp])
  @@index([type])
  @@index([hubspot_id])
  @@map("advisor_activities")
}

// Sync job tracking to monitor daily syncs
model SyncJob {
  id              String   @id @default(cuid())

  // Job Details
  job_type        String   // full_sync, single_advisor, activities_sync
  status          String   // pending, running, completed, failed

  // Statistics
  records_synced  Int?
  records_failed  Int?
  error_message   String?  @db.Text

  // Timing
  started_at      DateTime @default(now())
  completed_at    DateTime?
  duration_ms     Int?

  @@index([job_type])
  @@index([status])
  @@index([started_at])
  @@map("sync_jobs")
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSITIONS MANAGEMENT (Google Sheets → PostgreSQL Cache)
// ═══════════════════════════════════════════════════════════════════════════

// Transition client records from Google Sheets workbooks
model TransitionClient {
  id                              Int       @id @default(autoincrement())

  // Sheet Metadata
  sheet_id                        String
  sheet_row_index                 Int
  workbook_name                   String?

  // Assignment & Ownership
  farther_contact                 String?
  advisor_name                    String?

  // Account Details
  custodian                       String?
  account_type                    String?
  account_name                    String?
  new_account_number              String?
  contra_account_firm             String?
  contra_account_numbers          String?

  // Status Tracking
  document_readiness              String?
  status_of_iaa                   String?
  status_of_account_paperwork     String?
  portal_status                   String?

  // DocuSign Integration
  docusign_iaa_status             String?
  docusign_paperwork_status       String?
  docusign_iaa_envelope_id        String?
  docusign_paperwork_envelope_id  String?

  // Household & Billing
  household_name                  String?
  billing_group                   String?
  fee_schedule                    String?
  billing_exceptions              String?
  billing_exception_explanation   String?
  billing_setup                   String?

  // Primary Contact
  primary_first_name              String?
  primary_middle_name             String?
  primary_last_name               String?
  primary_email                   String?
  primary_phone                   String?
  primary_dob                     String?
  primary_ssn_last4               String?
  primary_street                  String?
  primary_city                    String?
  primary_state                   String?
  primary_zip                     String?
  primary_country                 String?

  // Secondary Contact
  secondary_first_name            String?
  secondary_middle_name           String?
  secondary_last_name             String?
  secondary_email                 String?
  secondary_phone                 String?
  secondary_dob                   String?
  secondary_ssn_last4             String?
  secondary_street                String?
  secondary_city                  String?
  secondary_state                 String?
  secondary_zip                   String?
  secondary_country               String?

  // Mailing Address
  mailing_street                  String?
  mailing_city                    String?
  mailing_state                   String?
  mailing_zip                     String?
  mailing_country                 String?

  // Operations
  portal_invites                  String?
  welcome_gift_box                String?
  notes                           String?  @db.Text

  // Data Quality Tracking (Phase 1)
  data_quality                    Json?     // Field-level quality metadata
  completeness_pct                Float?    // 0-100 percentage of non-null fields
  critical_fields_ok              Boolean   @default(false) // All 3 critical fields present
  quality_alerts                  String?   @db.Text // JSON array of alert objects

  // Sync Metadata
  synced_at                       DateTime  @default(now())
  created_at                      DateTime  @default(now())
  updated_at                      DateTime  @updatedAt

  @@unique([sheet_id, sheet_row_index])
  @@index([sheet_id])
  @@index([advisor_name])
  @@index([farther_contact])
  @@index([status_of_iaa])
  @@index([status_of_account_paperwork])
  @@index([portal_status])
  @@index([household_name])
  @@index([primary_email])
  @@index([docusign_iaa_status])
  @@index([docusign_paperwork_status])
  @@index([completeness_pct])
  @@index([critical_fields_ok])
  @@index([synced_at])
  @@map("transition_clients")
}

// Workbook metadata with Google Drive sync tracking
model TransitionWorkbook {
  id                      String    @id @default(cuid())
  sheet_id                String    @unique

  // Workbook Details
  workbook_name           String
  sheet_url               String?

  // Advisor Assignment
  detected_advisor_name   String?
  assigned_advisor_name   String?   // Manual override
  assignment_locked       Boolean   @default(false)

  // Google Drive Sync
  drive_modified_time     DateTime?
  last_synced_at          DateTime  @default(now())

  // Import Quality Tracking (Phase 1)
  import_metadata         Json?     // Workbook-level import stats
  data_quality_score      Float?    // 0-100 average completeness of all rows
  critical_rows_ok        Int       @default(0) // Count of rows with all critical fields
  total_rows              Int       @default(0)
  last_import_errors      String?   @db.Text // JSON array of import errors

  // Metadata
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@index([sheet_id])
  @@index([assigned_advisor_name])
  @@index([data_quality_score])
  @@index([last_synced_at])
  @@map("transition_workbooks")
}

// Advisor team name mappings (individual → team)
model AdvisorTeamMapping {
  id                Int      @id @default(autoincrement())
  individual_name   String   @unique
  team_name         String

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([team_name])
  @@map("advisor_team_mappings")
}

// Advisor transition AUM and revenue aggregates
model AdvisorTranAum {
  id            Int      @id @default(autoincrement())
  advisor_name  String   @unique

  tran_aum      Decimal  @default(0) @db.Decimal(15,2)
  revenue       Decimal  @default(0) @db.Decimal(15,2)

  last_updated  DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([advisor_name])
  @@map("advisor_tran_aum")
}
