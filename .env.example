# Farther AX Command Center - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Required)
# ═══════════════════════════════════════════════════════════════════════════════
# Format: postgresql://user:password@host:port/database
# Railway auto-provides this in production
DATABASE_URL=postgresql://postgres:password@localhost:5432/farther_ax
NODE_ENV=development  # development | production

# ═══════════════════════════════════════════════════════════════════════════════
# NEXTAUTH (Required for authentication)
# ═══════════════════════════════════════════════════════════════════════════════
# Full URL of your deployed site (no trailing slash)
# Development: http://localhost:3000
# Production: https://your-railway-domain.up.railway.app
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH (Required for login)
# ═══════════════════════════════════════════════════════════════════════════════
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE SERVICE ACCOUNT (Required for Drive & Sheets integration)
# ═══════════════════════════════════════════════════════════════════════════════
# Option 1: Credentials file path (local development)
GOOGLE_APPLICATION_CREDENTIALS=

# Option 2: JSON content (Railway preferred - paste full JSON as single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option 3: Separate credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Drive folder ID for transition workbooks
# (last part of folder URL after /folders/)
GOOGLE_DRIVE_FOLDER_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# HUBSPOT CRM (Required)
# ═══════════════════════════════════════════════════════════════════════════════
# Private app access token from: https://app.hubspot.com/private-apps
# System tries HUBSPOT_ACCESS_TOKEN first, then falls back to HUBSPOT_PAT
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PAT=

# For webhook verification (get from HubSpot app settings)
HUBSPOT_CLIENT_SECRET=

# Legacy/deprecated - not actively used
HUBSPOT_DEVELOPER_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# DOCUSIGN (Required for e-signature integration)
# ═══════════════════════════════════════════════════════════════════════════════
# Integration key and credentials from: https://admindemo.docusign.com/apps-and-keys
# Or production: https://account.docusign.com/apps-and-keys
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_API_ACCOUNT_ID=
DOCUSIGN_USER_ID=

# Base URI (demo for testing, production for live)
DOCUSIGN_BASE_URI=https://demo.docusign.net  # or https://na4.docusign.net for production

# OAuth server (demo: https://account-d.docusign.com, production: https://account.docusign.com)
DOCUSIGN_AUTH_SERVER=https://account.docusign.com

# HMAC secret for webhook verification (set in DocuSign Connect)
DOCUSIGN_HMAC_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# AWS S3 (Required for file uploads - advisor documents)
# ═══════════════════════════════════════════════════════════════════════════════
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CACHE (Optional - graceful degradation if not set)
# ═══════════════════════════════════════════════════════════════════════════════
# Format: redis://default:password@host:port
# Railway provides this automatically if you add Redis service
REDIS_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# GROK / XAI (Optional - for AI assistant features)
# ═══════════════════════════════════════════════════════════════════════════════
# API key from: https://console.x.ai
GROK_API_KEY=
XAI_API_KEY=  # Alias for GROK_API_KEY

# ═══════════════════════════════════════════════════════════════════════════════
# AIZOLO (Optional - for AI email generation features)
# ═══════════════════════════════════════════════════════════════════════════════
# API key from: https://chat.aizolo.com
AIZOLO_API_KEY=
AIZOLO_BASE_URL=https://chat.aizolo.com/api/v1

# ═══════════════════════════════════════════════════════════════════════════════
# ENCRYPTION (Required for sensitive form data - SSN, DOB, etc.)
# ═══════════════════════════════════════════════════════════════════════════════
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTAKE_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Optional - defaults provided)
# ═══════════════════════════════════════════════════════════════════════════════
# Email addresses for form notifications
COMPLIANCE_EMAIL=compliance@farther.com
AXM_EMAIL=ax@farther.com
AX_SENDER_EMAIL=ax@farther.com

# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY AUTO-PROVIDED (Do not set manually - Railway sets these automatically)
# ═══════════════════════════════════════════════════════════════════════════════
# RAILWAY_PUBLIC_DOMAIN=yourapp.railway.app
# NEXT_PUBLIC_APP_URL=https://yourapp.railway.app
